# deploy/.env.example —— 端侧部署环境变量模板（MOD-deploy P0-1）
#
# 用法（Windows 端侧 / 容器）：
#   1. 复制为 .env.local：  cp deploy/.env.example deploy/.env.local
#   2. 填入真实值（仅本地，.env.local 已被 .gitignore 忽略，禁止提交）
#   3. 运行：AGENT_LLM_KIND=cloud ... python src/main.py deploy/enterprise.yaml
#
# 优先级：环境变量 > enterprise.yaml（端侧不改 yaml 即可切换模式）。
# 所有密钥仅经 env 注入，绝不打包进镜像 / 提交进仓库。

# ---- 企业标识 ----
AGENT_ENTERPRISE_ID=demo
# AGENT_DB_PATH=/app/data/kb.db

# ---- LLM（端侧可选 ollama 不出网；云 API 才出网，须配置下方 base_url + api_key）----
AGENT_LLM_KIND=mock            # mock | ollama | cloud
AGENT_LLM_MODEL=
AGENT_LLM_BASE_URL=
AGENT_LLM_API_KEY=             # 云 API key（如 sk-...），仅 env 注入，勿写进 yaml
AGENT_LLM_TEMPERATURE=0.2
AGENT_LLM_MAX_TOKENS=1024

# ---- Embedding ----
AGENT_EMBEDDING_KIND=bge-small-zh   # mock | bge-small-zh

# ---- 微信 iLink（bot 凭证，仅 env 注入）----
AGENT_BOT_TOKEN=              # iLink bot_token，占位：<从 iLink 开放平台获取>

# ---- 安全（P0）----
# 健康数据加密密钥：base64 编码的 32 字节 Fernet key。
# 生成：python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 生产/部署模式缺失此变量将启动失败（禁止明文落库）。
AGENT_DATA_ENCRYPTION_KEY=

# 出入站白名单强制：0=关闭（开发/mock 透传），1=开启（仅白名单域名可出网）
AGENT_EGRESS_ENFORCE=0
# 白名单逃生阀（逗号分隔额外放通域名，部署侧临时放通）
# AGENT_EGRESS_EXTRA_HOSTS=mirror.corp.example.com
