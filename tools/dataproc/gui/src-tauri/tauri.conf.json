{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dataproc-gui",
  "version": "0.1.0",
  "identifier": "com.dataproc.gui",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter dataproc-gui dev",
    "beforeBuildCommand": "pnpm --filter dataproc-gui build"
  },
  "app": {
    "windows": [
      {
        "title": "数据处理工作台",
        "width": 1280,
        "height": 800,
        "dragDropEnabled": true,
        "contentProtection": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  },
  "plugins": {}
}
